{
  "name": "ink-book-reader",
  "version": "1.0.0",
  "description": "Ink Book Reader - Read EPUB, PDF, TXT, and HTML books",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build --watch & wait-on dist/index.html && electron .",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": ["epub", "pdf", "ebook", "reader", "electron"],
  "author": "Ink",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "dompurify": "^3.1.5",
    "electron-store": "^8.2.0",
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^4.5.136",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
